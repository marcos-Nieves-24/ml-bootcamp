{
  "name": "platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:interactives": "rsync -a --delete ../content/module01_ai/interactives/ public/interactives/",
    "check:interactives": "diff -r ../content/module01_ai/interactives/ public/interactives/",
    "build": "npm run build:interactives && next build",
    "setup:hooks": "git config core.hooksPath .githooks && echo '✅ hooksPath apunta a .githooks/'",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
"dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/prisma-adapter": "^1.0.9",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.474.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
