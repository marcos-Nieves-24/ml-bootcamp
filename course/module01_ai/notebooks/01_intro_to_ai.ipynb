   "cell_type": "code",
   "execution_count": 4,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-04T17:38:15.765498Z",
     "iopub.status.busy": "2026-07-04T17:38:15.765062Z",
     "iopub.status.idle": "2026-07-04T17:38:15.776145Z",
