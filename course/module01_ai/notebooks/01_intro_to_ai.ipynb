    "## Lección 5: Aplicaciones de IA — Sistema de Recomendación"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-04T17:38:16.012171Z",
     "iopub.status.busy": "2026-07-04T17:38:16.011832Z",
     "iopub.status.idle": "2026-07-04T17:38:16.022510Z",
     "shell.execute_reply": "2026-07-04T17:38:16.020366Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Recommendation System (Collaborative Filtering):\n",
      "  User 0: No new recommendations\n",
      "  User 1: No new recommendations\n",
      "  User 2: No new recommendations\n",
      "  User 3: Recommend items [0, 1]\n",
      "  User 4: Recommend items [2]\n"
     ]
    }
   ],
   "source": [
    "ratings = np.array([\n",
    "    [5, 4, 0, 0, 1],\n",
    "    [4, 5, 0, 0, 2],\n",
    "    [0, 0, 5, 4, 0],\n",
    "    [0, 0, 4, 5, 3],\n",
    "    [1, 2, 0, 3, 5],\n",
    "])\n",
    "\n",
    "def recommend(ratings, user_id):\n",
    "    target = ratings[user_id]\n",
    "    similarities = []\n",
    "    for i in range(len(ratings)):\n",
    "        if i == user_id:\n",
    "            continue\n",
    "        common = (target > 0) & (ratings[i] > 0)\n",
    "        if common.sum() == 0:\n",
    "            sim = 0\n",
    "        else:\n",
    "            diff = np.abs(target[common] - ratings[i][common])\n",
    "            sim = 1 / (1 + diff.mean())\n",
    "        similarities.append((i, sim))\n",
    "    \n",
    "    most_similar = max(similarities, key=lambda x: x[1])[0]\n",
    "    recs = [j for j in range(ratings.shape[1])\n",
    "            if target[j] == 0 and ratings[most_similar][j] >= 4]\n",
    "    return recs\n",
    "\n",
    "print(\"Recommendation System (Collaborative Filtering):\")\n",
    "for uid in range(5):\n",
    "    recs = recommend(ratings, uid)\n",
    "    if recs:\n",
    "        print(f\"  User {uid}: Recommend items {recs}\")\n",
    "    else:\n",
    "        print(f\"  User {uid}: No new recommendations\")"
   ]
  },
