    "## 3. Probabilidad\n",
    "\n",
    "Teorema de Bayes: prueba de diagnóstico médico."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-07-04T17:41:14.252213Z",
     "iopub.status.busy": "2026-07-04T17:41:14.251848Z",
     "iopub.status.idle": "2026-07-04T17:41:14.259551Z",
     "shell.execute_reply": "2026-07-04T17:41:14.257284Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "P(disease|positive) = 0.088\n"
     ]
    }
   ],
   "source": [
    "prevalence = 0.01\n",
    "sensitivity = 0.95\n",
    "specificity = 0.90\n",
    "posterior = (sensitivity * prevalence) / (\n",
    "    sensitivity * prevalence + (1 - specificity) * (1 - prevalence)\n",
    ")\n",
    "print(f\"P(disease|positive) = {posterior:.3f}\")"
   ]
  },
